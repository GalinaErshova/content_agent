# Скопируйте этот файл в .env и заполните, чтобы включить Yandex / трассировку.
# Без .env (или с backend=mock) проект работает офлайн на mock-провайдерах.

# --- Бэкенды провайдеров: mock | yandex ---
LLM_BACKEND=mock
EMBEDDING_BACKEND=mock
IMAGE_BACKEND=mock

# --- RAG: memory (numpy, офлайн) | faiss (LangChain + FAISS) ---
# Для faiss установите группу зависимостей: pip install -e ".[rag]"
RAG_BACKEND=memory

# --- Ключи Yandex Cloud (нужны только при *_BACKEND=yandex) ---
# Где взять: консоль Yandex Cloud → сервисный аккаунт → API-ключ; folder_id — id каталога.
YC_API_KEY=
YC_FOLDER_ID=

# --- Корень с задачами (необязательно; по умолчанию ./projects) ---
# PROJECTS_ROOT=projects

# --- Трассировка LangSmith (необязательно) ---
# Включить трассировку прогонов: смотреть граф, узлы и вызовы модели на smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=education-content-agents
